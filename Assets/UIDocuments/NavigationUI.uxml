<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="MainContainer" picking-mode="Ignore" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
        <ui:VisualElement name="FadeOverlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgb(0, 0, 0); display: none; transition-property: opacity; transition-duration: 0.5s; transition-timing-function: ease-in-out;"/>
    </ui:VisualElement>
</ui:UXML>
